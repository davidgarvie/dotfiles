{
    // editor
    "editor.fontFamily": "'Dank Mono', Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 20,
    "editor.wordWrap": "on",
    "editor.renderWhitespace": "all",
    "editor.tabSize": 2,
  
    // source control
    "diffEditor.ignoreTrimWhitespace": true,
    "git.autofetch": true,
    "git.confirmSync": false,
  
    // terminal
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.fontSize": 18,
    "terminal.integrated.shell.linux": "zsh",
    "terminal.integrated.shell.osx": "zsh",
  
    // vscode
    "breadcrumbs.enabled": true,
    "explorer.confirmDragAndDrop": false,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "telemetry.enableTelemetry": false,
    "window.zoomLevel": -1,
    "workbench.startupEditor": "none",

    // plugins
    "go.formatTool": "goimports",
    "go.useLanguageServer": true,
    "vs-kubernetes": {
      "vs-kubernetes.helm-path": "/Users/davidgarvie/.vs-kubernetes/tools/helm/darwin-amd64/helm",
      "vs-kubernetes.draft-path": "/Users/davidgarvie/.vs-kubernetes/tools/draft/darwin-amd64/draft",
      "vs-kubernetes.minikube-path": "/Users/davidgarvie/.vs-kubernetes/tools/minikube/darwin-amd64/minikube"
    },
  }